---
extends: default

rules:
  line-length:
    max: 120
    level: warning
  truthy:
    # Allow GitHub Actions' `on:` key.
    check-keys: false
  comments:
    min-spaces-from-content: 1
  document-start:
    present: true
  indentation:
    spaces: 2
    indent-sequences: true

ignore: |
  site/
  .venv/
  node_modules/
